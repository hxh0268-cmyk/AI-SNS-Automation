    "smart-auto-fix": "node src/smart_auto_fix.js",
    "daily": "bash scripts/run_daily.sh",
    "quality-pipeline": "node scripts/run_quality_pipeline.js",
    "quality-pipeline:dry-run": "node scripts/run_quality_pipeline.js --dry-run",
